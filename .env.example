# ─── Supabase ───────────────────────────────────────────────────────────────
# Found in: Supabase Dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

# ─── Google Gemini AI ────────────────────────────────────────────────────────
# Found in: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key

# ─── Weather APIs ────────────────────────────────────────────────────────────
# OpenWeather: https://openweathermap.org/api
NEXT_PUBLIC_OPENWEATHER_API_KEY=your_openweather_api_key
# Google Weather (via Google Cloud Console)
GOOGLE_WEATHER_API_KEY=your_google_weather_api_key

# ─── Feature Flags ───────────────────────────────────────────────────────────
# Set to "true" to enable Gemini product image generation on wardrobe upload.
# When disabled, original images are uploaded directly (saves Gemini quota).
ENABLE_PRODUCT_IMAGE_GENERATION=true
